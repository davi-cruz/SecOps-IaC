rule apr29_unc6692_malicious_execution_temp {

  meta:
    author = "Gemini CLI"
    description = "Detects execution of binaries from Windows Temp directories, a common TTP for UNC6692."
    severity = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    $e.target.process.file.full_path = /.*\\AppData\\Local\\Temp\\.*\.exe/ or $e.target.process.file.full_path = /.*\\Windows\\Temp\\.*\.exe/

  condition:
    $e
}
