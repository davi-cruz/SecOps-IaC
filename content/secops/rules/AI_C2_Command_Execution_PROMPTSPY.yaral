rule AI_C2_Command_Execution_PROMPTSPY {

  meta:
    author = "Gemini CLI"
    description = "Detects processes connecting to AI APIs (Gemini, OpenAI, Anthropic) and subsequently executing commands, characteristic of PROMPTSPY and AI-enabled autonomous malware."
    severity = "CRITICAL"
    reference = "https://cloud.google.com/blog/topics/threat-intelligence/ai-vulnerability-exploitation-initial-access"

  events:
    $net.metadata.event_type = "NETWORK_CONNECTION"
    (
      $net.target.hostname = "generativelanguage.googleapis.com" or
      $net.target.hostname = "api.openai.com" or
      $net.target.hostname = "api.anthropic.com"
    )
    $net.principal.hostname = $hostname

    $proc.metadata.event_type = "PROCESS_LAUNCH"
    $proc.principal.hostname = $hostname
    // The process that made the network connection should be related to the execution
    $net.principal.process.pid = $proc.principal.process.pid

  match:
    $hostname over 5m

  condition:
    $net and $proc
}