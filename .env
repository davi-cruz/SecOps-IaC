# Google SecOps API Configuration (Dummy values for local validation/testing)
# Replace these with your actual GCP/SecOps values if you need to run live sync commands.

GOOGLE_CLOUD_PROJECT_ID=dummy-project-id
GOOGLE_SECOPS_INSTANCE=projects/123456789012/locations/us/instances/00000000-0000-0000-0000-000000000000
GOOGLE_SECOPS_API_BASE_URL=https://us-chronicle.googleapis.com/v1
GOOGLE_SECOPS_API_UPLOAD_BASE_URL=https://us-chronicle.googleapis.com/upload/v1

# Required JSON-formatted scopes for authentication initialization
AUTHORIZATION_SCOPES={"GOOGLE_SECOPS_API":["https://www.googleapis.com/auth/cloud-platform"]}

# Local debugging configuration
LOGGING_LEVEL=DEBUG
